# ============================================
# Invoice Generator - Environment Configuration
# ============================================
# Copy this file to .env and customize as needed.
# All paths can be absolute or relative to project root.

# --- Blueprint Paths ---
# Root directory for all blueprint assets
BLUEPRINTS_ROOT=database/blueprints

# BUNDLED DIRECTORY: Contains customer folders with config + template together
# Structure: bundled/{CustomerCode}/
#   - {CustomerCode}_config.json (or _bundle_config.json)
#   - {CustomerCode}.xlsx (template)
#   - (optional) {CustomerCode}_template.json (JSON template)
#   - (optional) metadata files
BUNDLED_DIR=database/blueprints/bundled

# Header mapping configuration file
MAPPING_CONFIG=database/blueprints/mapper/mapping_config.json

# --- Output Paths ---
# Directory for generated invoice files
OUTPUT_DIR=database/generated_invoices

# Directory for temporary uploaded files during processing
TEMP_UPLOADS_DIR=database/temp_uploads

# Directory for pipeline run logs and traces
RUN_LOG_DIR=run_log

# --- Default Template ---
# Fallback template name when specific template not found
FALLBACK_TEMPLATE=JF.xlsx

# --- Frontend ---
# Directory containing frontend static files
FRONTEND_DIR=frontend

