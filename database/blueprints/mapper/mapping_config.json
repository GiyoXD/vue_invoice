    "fallback_strategies": {
        "comment": "Configuration for handling unrecognized headers and sheets",
        "case_insensitive_matching": true,
        "partial_matching_threshold": 0.7,
        "log_unrecognized_items": true,
        "create_suggestions": true
    },
