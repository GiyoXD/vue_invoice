  "layout_bundle": {
    "_comment": "Layout configuration - structure, data flow, content, and footer rules",
    "defaults": {
      "_comment": "Shared mappings inherited by all sheets. Per-sheet mappings override these.",
      "data_flow": {
        "mappings": {
          "col_unit_sf": {
            "fallback": {
              "default": "SF"
            }
          },
          "col_po": {},
          "col_item": {},
          "col_desc": {
            "fallback": {
              "standard": "LEATHER",
              "daf": "LEATHER"
            }
          },
          "col_qty_sf": {},
          "col_unit_price": {
            "formula": {
              "daf": "{col_amount} / {col_qty_sf}",
              "custom": "{col_amount} / {col_qty_sf}"
            }
          },
          "col_amount": {
            "formula": {
              "standard": "{col_qty_sf} * {col_unit_price}"
            }
          },
          "col_sqm": {
            "formula": {
              "standard": "{col_qty_sf} * 0.092903",
              "daf": "{col_qty_sf} * 0.092903",
              "custom": "{col_qty_sf} * 0.092903"
            }
          }
        }
      },
      "footer": {
        "sum_cols": [
          "col_qty_pcs",
          "col_qty_sf",
          "col_amount",
          "col_net",
          "col_gross",
          "col_cbm",
          "col_sqm"
        ]
      }
    },
    "Invoice": {
      "_sections": [
        "structure",
        "data_flow",
        "content",
        "footer"
      ],
      "structure": {
        "header_row": 21,
        "columns": [
          {
            "id": "col_static",
